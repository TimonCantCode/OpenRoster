NODE_ENV=production
APP_URL=http://localhost:3000
APP_SECRET=replace-with-at-least-32-random-characters

DATABASE_URL=postgresql://openroster:replace-with-a-strong-database-password@postgres:5432/openroster

POSTGRES_USER=openroster
POSTGRES_PASSWORD=replace-with-a-strong-database-password
POSTGRES_DB=openroster

SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="OpenRoster <noreply@localhost>"
SMTP_SECURE=false

INVITE_TOKEN_TTL_DAYS=7
SESSION_TTL_DAYS=30

RUN_SEED=false
SEED_OWNER_EMAIL=
SEED_OWNER_PASSWORD=
SEED_OWNER_NAME=
SEED_ORGANIZATION_NAME=
